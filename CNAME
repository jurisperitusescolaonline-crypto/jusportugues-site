<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Jurisperitus — Português Jurídico e Concursos | Brasília</title>
  <meta name="description" content="Cursos, e-books e IA para dominar Português jurídico e conquistar sua aprovação. Prof. Freire — referência em Português para concursos." />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Source+Sans+3:wght@300;400;600;700&display=swap" rel="stylesheet" />
  <style>
    :root {
      --azul: #003B83;
      --azul-escuro: #002560;
      --azul-medio: #0a4fa3;
      --dourado: #FFB400;
      --dourado-escuro: #cc9000;
      --branco: #FFFFFF;
      --cinza-claro: #F7F8FC;
      --cinza-medio: #e8eaf0;
      --cinza-texto: #555C6E;
      --sombra: 0 8px 40px rgba(0,59,131,0.13);
      --sombra-card: 0 4px 24px rgba(0,59,131,0.10);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Source Sans 3', sans-serif;
      color: var(--azul-escuro);
      background: var(--branco);
      overflow-x: hidden;
    }

    /* ── HEADER ── */
    header {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      background: rgba(0,37,96,0.97);
      backdrop-filter: blur(10px);
      padding: 0 5%;
      height: 70px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      box-shadow: 0 2px 20px rgba(0,0,0,0.25);
    }

    .logo-text {
      font-family: 'Playfair Display', serif;
      font-size: 1.55rem;
      font-weight: 900;
      color: var(--branco);
      letter-spacing: 0.04em;
      line-height: 1;
    }

    .logo-text span {
      color: var(--dourado);
    }

    .logo-sub {
      font-size: 0.65rem;
      color: rgba(255,255,255,0.55);
      letter-spacing: 0.18em;
      text-transform: uppercase;
      margin-top: 2px;
    }

    .header-cta {
      background: var(--dourado);
      color: var(--azul-escuro);
      font-family: 'Source Sans 3', sans-serif;
      font-weight: 700;
      font-size: 0.85rem;
      letter-spacing: 0.05em;
      padding: 10px 22px;
      border-radius: 4px;
      text-decoration: none;
      text-transform: uppercase;
      transition: background 0.2s, transform 0.2s;
      white-space: nowrap;
    }

    .header-cta:hover {
      background: var(--dourado-escuro);
      transform: translateY(-1px);
    }

    /* ── HERO ── */
    .hero {
      min-height: 100vh;
      background: linear-gradient(135deg, var(--azul-escuro) 0%, var(--azul) 55%, #0a4fa3 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 120px 5% 80px;
      position: relative;
      overflow: hidden;
    }

    .hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse 70% 60% at 20% 80%, rgba(255,180,0,0.07) 0%, transparent 60%),
        radial-gradient(ellipse 50% 50% at 80% 20%, rgba(255,255,255,0.04) 0%, transparent 60%);
    }

    .hero-badge {
      display: inline-block;
      background: rgba(255,180,0,0.15);
      border: 1px solid rgba(255,180,0,0.4);
      color: var(--dourado);
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      padding: 6px 18px;
      border-radius: 50px;
      margin-bottom: 28px;
      animation: fadeUp 0.8s ease both;
    }

    .hero h1 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2.4rem, 6vw, 4.2rem);
      font-weight: 900;
      color: var(--branco);
      line-height: 1.12;
      margin-bottom: 24px;
      animation: fadeUp 0.9s 0.1s ease both;
    }

    .hero h1 em {
      color: var(--dourado);
      font-style: normal;
    }

    .hero p {
      font-size: clamp(1rem, 2vw, 1.2rem);
      color: rgba(255,255,255,0.78);
      max-width: 600px;
      margin: 0 auto 44px;
      line-height: 1.7;
      font-weight: 300;
      animation: fadeUp 1s 0.2s ease both;
    }

    .hero-btns {
      display: flex;
      gap: 16px;
      justify-content: center;
      flex-wrap: wrap;
      animation: fadeUp 1s 0.3s ease both;
    }

    .btn-primary {
      background: var(--dourado);
      color: var(--azul-escuro);
      font-weight: 700;
      font-size: 1rem;
      letter-spacing: 0.04em;
      padding: 16px 38px;
      border-radius: 5px;
      text-decoration: none;
      text-transform: uppercase;
      transition: all 0.25s;
      box-shadow: 0 6px 28px rgba(255,180,0,0.35);
    }

    .btn-primary:hover {
      background: var(--dourado-escuro);
      transform: translateY(-2px);
      box-shadow: 0 10px 36px rgba(255,180,0,0.45);
    }

    .btn-secondary {
      background: transparent;
      color: var(--branco);
      font-weight: 600;
      font-size: 1rem;
      padding: 16px 38px;
      border-radius: 5px;
      text-decoration: none;
      border: 1.5px solid rgba(255,255,255,0.35);
      transition: all 0.25s;
    }

    .btn-secondary:hover {
      border-color: var(--dourado);
      color: var(--dourado);
    }

    .hero-stats {
      display: flex;
      gap: 48px;
      justify-content: center;
      flex-wrap: wrap;
      margin-top: 72px;
      padding-top: 48px;
      border-top: 1px solid rgba(255,255,255,0.12);
      animation: fadeUp 1s 0.45s ease both;
    }

    .stat-item { text-align: center; }

    .stat-num {
      font-family: 'Playfair Display', serif;
      font-size: 2.2rem;
      font-weight: 900;
      color: var(--dourado);
      display: block;
    }

    .stat-label {
      font-size: 0.8rem;
      color: rgba(255,255,255,0.55);
      letter-spacing: 0.12em;
      text-transform: uppercase;
      margin-top: 4px;
    }

    /* ── QUEM SOMOS ── */
    .quem-somos {
      background: var(--branco);
      padding: 100px 5%;
    }

    .container { max-width: 1100px; margin: 0 auto; }

    .qs-grid {
      display: grid;
      grid-template-columns: 1fr 1.5fr;
      gap: 80px;
      align-items: center;
    }

    .qs-foto-wrap {
      position: relative;
    }

    .qs-foto-placeholder {
      width: 100%;
      aspect-ratio: 3/4;
      background: linear-gradient(145deg, var(--cinza-medio) 0%, #d0d5e8 100%);
      border-radius: 8px;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      color: var(--azul);
      font-size: 0.85rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      gap: 12px;
      box-shadow: var(--sombra);
    }

    .qs-foto-placeholder svg {
      width: 56px;
      height: 56px;
      opacity: 0.35;
    }

    .qs-foto-note {
      font-size: 0.72rem;
      color: var(--cinza-texto);
      text-align: center;
      margin-top: 10px;
      font-style: italic;
    }

    .tag-destaque {
      display: inline-block;
      background: rgba(0,59,131,0.08);
      color: var(--azul);
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      padding: 5px 14px;
      border-radius: 50px;
      margin-bottom: 20px;
    }

    .qs-texto h2 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.9rem, 3vw, 2.7rem);
      font-weight: 700;
      color: var(--azul-escuro);
      line-height: 1.2;
      margin-bottom: 24px;
    }

    .qs-texto h2 span { color: var(--dourado); }

    .qs-texto p {
      font-size: 1.05rem;
      color: var(--cinza-texto);
      line-height: 1.8;
      margin-bottom: 20px;
    }

    .titulos-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      margin-top: 32px;
    }

    .titulo-item {
      background: var(--cinza-claro);
      border-left: 3px solid var(--dourado);
      padding: 12px 16px;
      border-radius: 0 5px 5px 0;
    }

    .titulo-item strong {
      display: block;
      font-size: 0.78rem;
      font-weight: 700;
      color: var(--azul);
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }

    .titulo-item span {
      font-size: 0.82rem;
      color: var(--cinza-texto);
      margin-top: 2px;
      display: block;
    }

    /* ── PRODUTOS ── */
    .produtos {
      background: var(--cinza-claro);
      padding: 100px 5%;
    }

    .section-header {
      text-align: center;
      margin-bottom: 60px;
    }

    .section-header h2 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(1.9rem, 3vw, 2.8rem);
      font-weight: 700;
      color: var(--azul-escuro);
      margin-bottom: 14px;
    }

    .section-header h2 span { color: var(--dourado); }

    .section-header p {
      font-size: 1.05rem;
      color: var(--cinza-texto);
      max-width: 560px;
      margin: 0 auto;
      line-height: 1.7;
    }

    .produtos-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 28px;
    }

    .produto-card {
      background: var(--branco);
      border-radius: 10px;
      padding: 40px 28px 32px;
      box-shadow: var(--sombra-card);
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      transition: transform 0.25s, box-shadow 0.25s;
      border-top: 4px solid var(--azul);
    }

    .produto-card:hover {
      transform: translateY(-6px);
      box-shadow: 0 12px 48px rgba(0,59,131,0.16);
    }

    .produto-card:nth-child(2) { border-top-color: var(--dourado); }
    .produto-card:nth-child(3) { border-top-color: #0a9e6e; }
    .produto-card:nth-child(4) { border-top-color: #7b4fc9; }

    .produto-icon {
      font-size: 2.4rem;
      margin-bottom: 20px;
    }

    .produto-card h3 {
      font-family: 'Playfair Display', serif;
      font-size: 1.25rem;
      font-weight: 700;
      color: var(--azul-escuro);
      margin-bottom: 12px;
      line-height: 1.25;
    }

    .produto-card p {
      font-size: 0.92rem;
      color: var(--cinza-texto);
      line-height: 1.7;
      flex: 1;
      margin-bottom: 28px;
    }

    .btn-card {
      display: inline-block;
      background: var(--azul);
      color: var(--branco);
      font-weight: 700;
      font-size: 0.82rem;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      padding: 11px 24px;
      border-radius: 4px;
      text-decoration: none;
      transition: background 0.2s;
    }

    .btn-card:hover { background: var(--azul-medio); }

    .produto-card:nth-child(2) .btn-card { background: var(--dourado); color: var(--azul-escuro); }
    .produto-card:nth-child(2) .btn-card:hover { background: var(--dourado-escuro); }
    .produto-card:nth-child(3) .btn-card { background: #0a9e6e; }
    .produto-card:nth-child(3) .btn-card:hover { background: #087a55; }
    .produto-card:nth-child(4) .btn-card { background: #7b4fc9; }
    .produto-card:nth-child(4) .btn-card:hover { background: #6038a8; }

    /* ── DIFERENCIAIS ── */
    .diferenciais {
      background: var(--branco);
      padding: 100px 5%;
    }

    .dif-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 32px;
      margin-top: 16px;
    }

    .dif-item {
      padding: 40px 32px;
      border-radius: 10px;
      background: var(--cinza-claro);
      border: 1px solid var(--cinza-medio);
      transition: border-color 0.2s, box-shadow 0.2s;
    }

    .dif-item:hover {
      border-color: var(--dourado);
      box-shadow: 0 6px 32px rgba(255,180,0,0.1);
    }

    .dif-icon {
      font-size: 2.6rem;
      margin-bottom: 20px;
      display: block;
    }

    .dif-item h3 {
      font-family: 'Playfair Display', serif;
      font-size: 1.2rem;
      font-weight: 700;
      color: var(--azul-escuro);
      margin-bottom: 12px;
    }

    .dif-item p {
      font-size: 0.95rem;
      color: var(--cinza-texto);
      line-height: 1.75;
    }

    /* ── DEPOIMENTOS ── */
    .depoimentos {
      background: linear-gradient(160deg, var(--azul-escuro) 0%, var(--azul) 100%);
      padding: 100px 5%;
      position: relative;
      overflow: hidden;
    }

    .depoimentos::before {
      content: '\201C';
      position: absolute;
      top: -30px;
      left: 3%;
      font-family: 'Playfair Display', serif;
      font-size: 22rem;
      color: rgba(255,255,255,0.04);
      line-height: 1;
      pointer-events: none;
    }

    .depoimentos .section-header h2 { color: var(--branco); }
    .depoimentos .section-header p { color: rgba(255,255,255,0.65); }

    .dep-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 28px;
    }

    .dep-card {
      background: rgba(255,255,255,0.07);
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 10px;
      padding: 36px 28px;
      backdrop-filter: blur(6px);
      transition: background 0.25s;
    }

    .dep-card:hover {
      background: rgba(255,255,255,0.11);
    }

    .dep-stars {
      color: var(--dourado);
      font-size: 1rem;
      letter-spacing: 3px;
      margin-bottom: 18px;
    }

    .dep-card blockquote {
      font-size: 0.98rem;
      color: rgba(255,255,255,0.88);
      line-height: 1.8;
      font-style: italic;
      margin-bottom: 28px;
      border: none;
      padding: 0;
    }

    .dep-autor {
      display: flex;
      align-items: center;
      gap: 14px;
    }

    .dep-avatar {
      width: 46px;
      height: 46px;
      border-radius: 50%;
      background: var(--dourado);
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      font-size: 1.1rem;
      color: var(--azul-escuro);
      flex-shrink: 0;
    }

    .dep-nome {
      font-weight: 700;
      font-size: 0.95rem;
      color: var(--branco);
    }

    .dep-cargo {
      font-size: 0.8rem;
      color: rgba(255,255,255,0.5);
      margin-top: 2px;
    }

    /* ── CTA FINAL ── */
    .cta-final {
      background: var(--azul-escuro);
      padding: 110px 5%;
      text-align: center;
      position: relative;
      overflow: hidden;
    }

    .cta-final::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse 80% 80% at 50% 100%, rgba(255,180,0,0.08) 0%, transparent 70%);
    }

    .cta-final .tag-destaque {
      background: rgba(255,180,0,0.15);
      color: var(--dourado);
      border: 1px solid rgba(255,180,0,0.3);
    }

    .cta-final h2 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(2rem, 4vw, 3.4rem);
      font-weight: 900;
      color: var(--branco);
      margin-bottom: 20px;
      line-height: 1.15;
    }

    .cta-final h2 em {
      color: var(--dourado);
      font-style: normal;
    }

    .cta-final p {
      font-size: 1.1rem;
      color: rgba(255,255,255,0.7);
      max-width: 520px;
      margin: 0 auto 48px;
      line-height: 1.7;
    }

    .btn-cta-grande {
      display: inline-block;
      background: var(--dourado);
      color: var(--azul-escuro);
      font-weight: 700;
      font-size: 1.1rem;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      padding: 20px 52px;
      border-radius: 5px;
      text-decoration: none;
      box-shadow: 0 8px 40px rgba(255,180,0,0.4);
      transition: all 0.25s;
    }

    .btn-cta-grande:hover {
      background: var(--dourado-escuro);
      transform: translateY(-3px);
      box-shadow: 0 14px 52px rgba(255,180,0,0.5);
    }

    /* ── FOOTER ── */
    footer {
      background: #001840;
      padding: 40px 5%;
      text-align: center;
      border-top: 1px solid rgba(255,255,255,0.08);
    }

    footer p {
      font-size: 0.82rem;
      color: rgba(255,255,255,0.35);
      line-height: 1.8;
    }

    footer a {
      color: rgba(255,180,0,0.7);
      text-decoration: none;
    }

    footer a:hover { color: var(--dourado); }

    /* ── ANIMAÇÕES ── */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(28px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ── RESPONSIVO ── */
    @media (max-width: 768px) {
      .qs-grid { grid-template-columns: 1fr; gap: 40px; }
      .qs-foto-wrap { max-width: 320px; margin: 0 auto; }
      .titulos-grid { grid-template-columns: 1fr; }
      .hero-stats { gap: 32px; }
      .header-cta { display: none; }
    }
  </style>
</head>
